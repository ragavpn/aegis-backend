PORT=3000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://oiqkhojsrbxjscgwkebj.supabase.co
# Get your Service Role key from the Supabase Dashboard -> Project Settings -> API
SUPABASE_SERVICE_KEY=

# Neo4j AuraDB (Required before starting)
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# Crucix
CRUCIX_BASE_URL=https://crucix-production-cf8e.up.railway.app
CRUCIX_SECRET=aegis-secret-key-12345

# ElevenLabs (Podcast Generation)
ELEVENLABS_API_KEY=
ELEVENLABS_HOST_VOICE_ID=EST9Ui6982FZPSi7gCHi
ELEVENLABS_GUEST_VOICE_ID=7WggD3IoWTIPT19PNyrW
ELEVENLABS_VOICE_ID=

# TTS Service Selection
# Options: "edge" (default) | "kokoroweb" | "huggingface" | "elevenlabs" | "local"
# "edge"      = Microsoft Edge Read Aloud TTS — NO API KEY required
# "kokoroweb" = Self-hosted Kokoro-web OpenAI-compatible API (ghcr.io/eduardolat/kokoro-web)
TTS_SERVICE=edge

# Microsoft Edge TTS voice (used when TTS_SERVICE=edge)
# Full list: https://learn.microsoft.com/azure/cognitive-services/speech-service/language-support
EDGE_TTS_VOICE=en-US-AriaNeural

# Kokoro-web (used when TTS_SERVICE=kokoroweb)
# ⚠️  SELF-HOSTED ONLY — voice-generator.pages.dev runs WebGPU in-browser; its POST API is not active
# Self-host: docker run -p 3000:3000 -e KW_SECRET_API_KEY=any-key ghcr.io/eduardolat/kokoro-web:latest
# On Railway: add as a new service (same project), set KOKORO_WEB_URL to private network URL
KOKORO_WEB_URL=http://kokoro-web.railway.internal:3000
KOKORO_WEB_API_KEY=any-key
KOKORO_WEB_VOICE=af_heart
KOKORO_WEB_MODEL=model_q8f16

# HuggingFace / Kokoro (used when TTS_SERVICE=huggingface)
HF_TOKEN=
HUGGINGFACE_VOICE_ID=af_heart

# Local Kokoro sidecar (used when TTS_SERVICE=local)
TTS_LOCAL_URL=http://aegis-tts.railway.internal:8000

# ElevenLabs (used when TTS_SERVICE=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
